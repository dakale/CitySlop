# Common flags
common --enable_bzlmod
common --lockfile_mode=error

# Build flags
build --verbose_failures

# Platform shorthand configs
build:macos_arm64 --platforms=//platforms:macos_arm64
build:macos_x86_64 --platforms=//platforms:macos_x86_64
build:linux_x86_64 --platforms=//platforms:linux_x86_64
build:linux_arm64 --platforms=//platforms:linux_arm64
build:windows_x86_64 --platforms=//platforms:windows_x86_64
build:windows_arm64 --platforms=//platforms:windows_arm64
